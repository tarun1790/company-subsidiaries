# Database & Cache Configurations
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/subsidiary_db
REDIS_URL=redis://localhost:6379/0

# LLM & Search API Keys
# Gemini API Key is required for company research, extraction, normalization, and confidence scoring
GEMINI_API_KEY=your_gemini_api_key_here
# Tavily API Key is optional; if missing, searches will fall back to DuckDuckGo/Wikipedia scrapers
TAVILY_API_KEY=your_tavily_api_key_here

# App Configurations
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
